[Script]
http-response ^https?:\/\/api\.adapty\.io\/api\/v1\/.*profile script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Yomu/yomu.js, requires-body=true, timeout=10, tag=Yomu Adapty Profile

http-response ^https?:\/\/fallback\.adapty\.io\/api\/v1\/.*profile script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Yomu/yomu.js, requires-body=true, timeout=10, tag=Yomu Adapty Fallback

http-response ^https?:\/\/api-cn\.adapty\.io\/api\/v1\/.*profile script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Yomu/yomu.js, requires-body=true, timeout=10, tag=Yomu Adapty CN

[MITM]
hostname = %APPEND% api.adapty.io, fallback.adapty.io, api-cn.adapty.io
