[MITM]
hostname = api.mycake.me, api.cakeapp.me

[Script]
http-response ^https?://api\.mycake\.me/(app/start|heart\b|tutorbot/ticket/policy|subscription/timesale/auto|v2/main/subscription/channel/updated) script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/(heart|user/dashboard|user/stars|user/s$) script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/(main/(today|keywords|subscription/channel/updated)|user/review/main|sentence/\d+/view/(contents/extra|relation)|channel/\d+/sentences) script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/(channel/playlist|snacks|$|/) script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
