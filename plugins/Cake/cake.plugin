#!name=Cake Premium Unlock
#!desc=Cake 会员解锁 v1.2 - 无限红心/AI导师/全部内容/课程/复习/关键词搜索
#!home=https://github.com/Leslie159357/Loon-Plugins
#!icon=https://static-mycake.pstatic.net/image/img_2309221549/1695607693176
#!author=Leslie159357
#!date=2026-05-25
#!version=1.2

[URL Rewrite]
^https?://api\.cakeapp\.me https://api.cakeapp.me header

[MITM]
hostname = api.mycake.me, api.cakeapp.me

[Script]
# --- api.mycake.me ---
http-response ^https?://api\.mycake\.me/app/start script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.mycake\.me/heart\b script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.mycake\.me/tutorbot/ticket/policy script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.mycake\.me/v2/main/subscription/channel/updated script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js

# --- api.cakeapp.me (GET) ---
http-response ^https?://api\.cakeapp\.me/gw/heart script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/user/dashboard script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/user/stars script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/main/today script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/main/keywords script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/main/subscription/channel/updated script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/sentence/\d+/view/contents/extra script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/sentence/\d+/view/relation script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/snacks script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/user/review/main script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw\/?(\?|$) script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/channel/playlist script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/channel/\d+/sentences script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/user/s$ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js

# --- api.cakeapp.me (POST) ---
http-response ^https?://api\.cakeapp\.me/gw/heart requires-body=true script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
