[Script]
http-response ^https?://api\.trancy\.org/1/user/profile script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js, requires-body=true, timeout=10, tag=Trancy API - User Profile
http-response ^https?://service\.trancy\.org/1/user/profile script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js, requires-body=true, timeout=10, tag=Service API - User Profile
http-response ^https?://api\.revenuecat\.com/ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js, requires-body=true, timeout=10, tag=RevenueCat API
http-response ^https?://api\.rc-backup\.com/ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js, requires-body=true, timeout=10, tag=RevenueCat Backup
http-response ^https?://api-paywalls\.revenuecat\.com/ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js, requires-body=true, timeout=10, tag=RevenueCat Paywalls

[MITM]
hostname = api.trancy.org, service.trancy.org, api.revenuecat.com, api.rc-backup.com, api-paywalls.revenuecat.com
