[Script]
http-response ^https?://api\.trancy\.org/1/user/profile requires-body=1, tag=Trancy API - User Profile, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js
http-response ^https?://service\.trancy\.org/1/user/profile requires-body=1, tag=Service API - User Profile, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js
http-response ^https?://api\.revenuecat\.com/ requires-body=1, tag=RevenueCat API, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js
http-response ^https?://api\.rc-backup\.com/ requires-body=1, tag=RevenueCat Backup, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js
http-response ^https?://api-paywalls\.revenuecat\.com/ requires-body=1, tag=RevenueCat Paywalls, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Trancy/trancy_mitm.js

[Host]
api.trancy.org = https
service.trancy.org = https
api.revenuecat.com = https
api.rc-backup.com = https
api-paywalls.revenuecat.com = https
