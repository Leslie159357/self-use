#!version=2.0
#!tag=cafe,game,猫屎咖啡,微信小游戏

[Script]
# 响应拦截: 读取数据时注入大数值
http-response ^https?:\/\/minigames\.liuzhaoling\.com\/userData\/getUserData script-path=https://raw.githubusercontent.com/Leslie159357/self-use/main/plugins/CatPoopCoffee/maomao_cat_mitm.js, requires-body=true, timeout=10, tag=猫屎咖啡 读取注入

# 请求拦截: 上传数据时保持大数值
http-request ^https?:\/\/minigames\.liuzhaoling\.com\/userData\/upsertUserData script-path=https://raw.githubusercontent.com/Leslie159357/self-use/main/plugins/CatPoopCoffee/maomao_cat_mitm.js, timeout=10, tag=猫屎咖啡 上传保持

[MITM]
hostname = %APPEND% minigames.liuzhaoling.com
